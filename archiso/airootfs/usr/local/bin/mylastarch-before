#!/bin/bash
echo "#################################"
echo "Start mylastarch-before"
echo "#################################"


echo "Populate Core Team keys"
echo "#################################"
pacman-key --init
pacman-key --populate
#pacman-key --populate mylastarch


echo "Changing into our own linux.preset"
echo "#################################"
mv /etc/mkinitcpio.d/mylastarch /etc/mkinitcpio.d/linux.preset

echo "Putting grub theme in again"
echo "#################################"
mkdir -p /boot/grub/themes
cp -Rf /usr/share/grub/themes/viper /boot/grub/themes/


echo "#################################"
echo "End mylastarch-before"
echo "#################################"
rm /usr/local/bin/mylastarch-before
